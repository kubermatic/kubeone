apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
namespace: kube-system

helmCharts:
- name: hcloud-cloud-controller-manager
  repo: https://charts.hetzner.cloud
  version: 1.34.0
  releaseName: hccm
  namespace: kube-system
  valuesFile: generate-values-ccm

patches:
  - patch: |-
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: hcloud-cloud-controller-manager
        namespace: kube-system
      spec:
        template:
          metadata:
            annotations:
              kubeone.k8c.io/credentials-hash: '{{ .CredentialsCCMHash }}'
          spec:
            # hostNetwork so DNS lookups (e.g. api.hetzner.cloud) go out over
            # the node's real interfaces instead of the CNI pod network, which
            # may be IPv4-only while the node's resolv.conf only has IPv6
            # resolvers.
            hostNetwork: true
            containers:
              - name: hcloud-cloud-controller-manager
                image: '{{ .InternalImages.Get "HetznerCCM" }}'
